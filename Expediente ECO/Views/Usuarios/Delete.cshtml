@model UsuariosListadoViewModel
@{
    ViewData["Title"] = "Administración de Usuarios";
}

<div class="container-fluid">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 text-primary"><i class="bi bi-people-fill me-2"></i> Gestión de Usuarios</h5>
        </div>
        <div class="card-body">

            @if (!string.IsNullOrEmpty(Model.Mensaje))
            {
                <div class="alert alert-info alert-dismissible fade show" role="alert">
                    <i class="bi bi-info-circle me-2"></i> @Model.Mensaje
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Usuario / Email</th>
                            <th class="text-center">Acciones de Rol</th>
                            <th class="text-center">Gestión de Cuenta</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var usuario in Model.Usuarios)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-sm me-3 bg-soft-primary text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                            <i class="bi bi-person"></i>
                                        </div>
                                        <span class="fw-medium">@usuario.Email</span>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <form asp-action="HacerAdmin" method="post" style="display:inline;">
                                        <input type="hidden" name="email" value="@usuario.Email" />
                                        <button type="submit" class="btn btn-outline-primary btn-sm rounded-pill px-3">
                                            <i class="bi bi-shield-plus me-1"></i> Hacer Admin
                                        </button>
                                    </form>

                                    <form asp-action="RemoverAdmin" method="post" style="display:inline;">
                                        <input type="hidden" name="email" value="@usuario.Email" />
                                        <button type="submit" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                                            <i class="bi bi-shield-minus me-1"></i> Quitar Admin
                                        </button>
                                    </form>
                                </td>
                                <td class="text-center">
                                    @if (usuario.Email != User.Identity.Name)
                                    {
                                        <form asp-action="EliminarUsuario" method="post"
                                              onsubmit="return confirm('¿Estás seguro de que deseas eliminar permanentemente al usuario @usuario.Email? Esta acción no se puede deshacer.')">
                                            <input type="hidden" name="email" value="@usuario.Email" />
                                            <button type="submit" class="btn btn-danger btn-sm rounded-pill px-3 shadow-sm">
                                                <i class="bi bi-trash3 me-1"></i> Eliminar
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-muted rounded-pill px-3">Sesión Activa</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Auto-cerrar alertas después de 5 segundos
        window.setTimeout(function() {
            $(".alert").fadeTo(500, 0).slideUp(500, function(){
                $(this).remove();
            });
        }, 5000);
    </script>
}