@model string 

@{
    ViewData["Title"] = "Recuperar Contraseña";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh; padding: 2rem 0;">
    <div class="card shadow-lg border-0 p-5" style="border-radius: 20px; max-width: 500px; width: 100%;">
        
        <div class="text-center mb-4">
            <div class="mb-3">
                <i class="bi bi-shield-lock" style="font-size: 3rem; color: var(--color-institucional);"></i>
            </div>
            <h3 class="fw-bold" style="color: var(--color-texto);">¿Problemas al entrar?</h3>
            <p class="text-muted small">Ingresa tu correo institucional y te enviaremos un enlace para recuperar el acceso a tu cuenta de ECO.</p>
        </div>

        <form asp-action="OlvidePassword" method="post">
            <div class="mb-4">
                <label class="form-label small fw-bold text-muted">Correo Institucional</label>
                <div class="input-group shadow-sm">
                    <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-envelope"></i></span>
                    <input name="email" type="email" class="form-control border-start-0 ps-0" 
                           placeholder="usuario@escuela.com" style="height: 50px;" required />
                </div>
            </div>

            <button type="submit" class="btn btn-primary w-100 btn-lg fw-bold shadow-sm mb-3"
                    style="background-color: var(--color-institucional); border: none; border-radius: 12px; font-size: 1rem;">
                Enviar enlace de recuperación
            </button>

            <div class="text-center">
                <a asp-action="Login" class="small text-decoration-none fw-bold" style="color: var(--color-institucional);">
                    <i class="bi bi-arrow-left me-1"></i> Volver al inicio de sesión
                </a>
            </div>
        </form>
    </div>
</div>