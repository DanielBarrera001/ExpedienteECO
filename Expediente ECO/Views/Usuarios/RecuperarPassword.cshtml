@model RecuperarPasswordViewModel

@{
    ViewData["Title"] = "Restablecer Contraseña";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh; padding: 2rem 0;">
    <div class="card shadow-lg border-0 p-5" style="border-radius: 20px; max-width: 500px; width: 100%;">

        <div class="text-center mb-4">
            <div class="mb-3">
                <i class="bi bi-key-fill" style="font-size: 3rem; color: var(--color-institucional);"></i>
            </div>
            <h3 class="fw-bold" style="color: var(--color-texto);">Nueva Contraseña</h3>
            <p class="text-muted small">Por favor, ingresa tu nueva clave de acceso para el Portal de Salud.</p>
        </div>

        <form asp-action="RecuperarPassword" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            @* CAMPOS OCULTOS - NO BORRAR *@
            <input type="hidden" asp-for="Email" />
            <input type="hidden" asp-for="CodigoReseteo" />

            <div class="mb-3">
                <label class="form-label small fw-bold text-muted">Nueva Contraseña</label>
                <div class="input-group shadow-sm">
                    <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-lock"></i></span>
                    <input asp-for="Password" type="password" class="form-control border-start-0 ps-0"
                           placeholder="Mínimo 6 caracteres" style="height: 50px;" required />
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label class="form-label small fw-bold text-muted">Confirmar Contraseña</label>
                <div class="input-group shadow-sm">
                    <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-lock-check"></i></span>
                    <input asp-for="ConfirmarPassword" type="password" class="form-control border-start-0 ps-0"
                           placeholder="Repite tu contraseña" style="height: 50px;" required />
                </div>
                <span asp-validation-for="ConfirmarPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100 btn-lg fw-bold shadow-sm mb-3"
                    style="background-color: var(--color-institucional); border: none; border-radius: 12px; font-size: 1rem;">
                Actualizar Contraseña
            </button>

            <div class="text-center">
                <a asp-action="Login" class="small text-decoration-none fw-bold" style="color: var(--color-institucional);">
                    Cancelar y volver al inicio
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}